# wp-to-nostr.ts – Umgebungsvariablen
# ---------------------------------------------------------------------------
# Im Live-Modus PFLICHT: privater Schlüssel zum Signieren der Events.
# Format: nsec1… oder 64-stelliges Hex.
NOSTR_PRIVATE_KEY=

# Wenn 'true', werden Events nur in der Konsole angezeigt, nicht publiziert.
DRY_RUN=false

# Wenn 'true', wird created_at einmalig auf "jetzt" gesetzt — ersetzt alle
# bestehenden Events auf dem Relay durch frische Versionen, auch wenn der
# WordPress-Post nicht modifiziert wurde. Nützlich nach Anreicherungs-
# Änderungen, die rückwirkend gelten sollen. Im Normalbetrieb 'false'.
FORCE_REPUBLISH=false

# Sync-Modus: 'calendar' (Default, Termine als kind:31923 NIP-52) oder
# 'article' (Long-Form-Beiträge als kind:30023 NIP-23). Pro Modus läuft eine
# eigene GitHub-Action: sync.yml für Termine, sync-articles.yml für Beiträge.
SYNC_MODE=calendar

# WordPress-REST-API-Endpunkt (Default: relilab.org).
WP_API_URL=https://relilab.org/wp-json/wp/v2/posts

# Kategorie-ID auf der WordPress-Seite. Default 176 = Termine; für
# SYNC_MODE=article z. B. 6 = Lernmodule.
WP_CATEGORY=176

# Komma-separierte Liste von Relay-URLs, an die Events publiziert werden.
# Failures auf einzelnen Relays brechen den Lauf nicht ab.
# NOSTR_RELAY (Singular) wird als Alternative noch akzeptiert (Rückwärts-
# kompatibilität); beide Werte werden zusammengeführt.
NOSTR_RELAYS=wss://relay-rpi.edufeed.org,wss://relay.edufeed.org,wss://theforest.nostr1.com,wss://relay.primal.net

# Komma-separierte Liste zusätzlicher Hashtags (t-Tags), die jedem Event
# angehängt werden, wenn nicht ohnehin aus WordPress-Tags vorhanden.
# Leer = keine Anreicherung. Führendes # ist optional.
# Beispiel: relilab,bildung
EXTRA_HASHTAGS=

# Komma-separierte Liste von Community-Identifiern (Communikey-Spec h-Tag).
# Akzeptiert npub1… oder 64-stelliges Hex. Leer = keine Community-Zuordnung.
# Beispiel: npub1fpcxaz2wvjl90gjs60x37ny2pa5u4yqfx7fklz73rgfjnnfujl3sr2fxgk
COMMUNITY_NPUBS=
